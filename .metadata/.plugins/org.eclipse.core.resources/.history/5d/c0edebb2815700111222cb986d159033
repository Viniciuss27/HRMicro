spring:
  application:
    name: hr-payroll
  cloud:
    openfeign:
      circuitbreaker:
        enabled: true

server:
  port: 8101

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka
  instance:
    prefer-ip-address: true

resilience4j:
  circuitbreaker:
    instances:
      workerService:
        slidingWindowSize: 10
        minimumNumberOfCalls: 2
        failureRateThreshold: 50
        waitDurationInOpenState: 5s

feign:
  client:
    config:
      default:
        decode404: true